{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vaultcompasshq.github.io/conductor/schemas/intent-contract/v1.json",
  "title": "Intent Contract",
  "description": "Frozen intent artifact for AI-assisted development sessions. Conductor schema v1.",
  "type": "object",
  "required": [
    "contract_id",
    "version",
    "original_ask",
    "in_scope",
    "out_of_scope",
    "constraints",
    "acceptance_criteria",
    "frozen_at",
    "pivot_log"
  ],
  "properties": {
    "contract_id": {
      "type": "string",
      "pattern": "^ic-[0-9]{8}-[a-z0-9]{6}$",
      "description": "Unique ID: ic-YYYYMMDD-random6"
    },
    "version": {
      "type": "string",
      "const": "1.0.0"
    },
    "original_ask": {
      "type": "string",
      "minLength": 10,
      "maxLength": 500,
      "description": "One-sentence summary of what the user asked for"
    },
    "in_scope": {
      "type": "array",
      "minItems": 1,
      "maxItems": 12,
      "items": {
        "type": "string",
        "minLength": 5,
        "maxLength": 200
      }
    },
    "out_of_scope": {
      "type": "array",
      "minItems": 0,
      "maxItems": 12,
      "items": {
        "type": "string",
        "minLength": 5,
        "maxLength": 200
      }
    },
    "constraints": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["source", "rule", "priority"],
        "properties": {
          "source": {
            "type": "string",
            "enum": [
              "AGENTS.md",
              "CLAUDE.md",
              "GEMINI.md",
              "cursor-rules",
              "user-stated",
              "user-correction",
              "superpowers-spec",
              "project-spec"
            ]
          },
          "rule": {
            "type": "string",
            "minLength": 5,
            "maxLength": 300
          },
          "priority": {
            "type": "string",
            "enum": ["critical", "high", "medium", "low"]
          },
          "file_path": {
            "type": "string"
          },
          "line_ref": {
            "type": "string"
          }
        }
      }
    },
    "acceptance_criteria": {
      "type": "array",
      "minItems": 1,
      "maxItems": 15,
      "items": {
        "type": "object",
        "required": ["id", "description", "testable"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^ac-[0-9]+$"
          },
          "description": {
            "type": "string",
            "minLength": 10,
            "maxLength": 300
          },
          "testable": {
            "type": "boolean"
          }
        }
      }
    },
    "frozen_at": {
      "type": "string",
      "format": "date-time"
    },
    "frozen_by": {
      "type": "string",
      "enum": ["user", "conductor", "agent"]
    },
    "approval": {
      "type": "object",
      "description": "Record of an explicit, attributable approval. Required for the contract to count as user-frozen by the gate.",
      "required": ["approved_by", "approved_at"],
      "properties": {
        "approved_by": {
          "type": "string",
          "minLength": 1,
          "maxLength": 120
        },
        "approved_at": {
          "type": "string",
          "format": "date-time"
        },
        "method": {
          "type": "string",
          "enum": ["interactive", "explicit-flag", "forced"]
        }
      }
    },
    "prompt_quality": {
      "type": "object",
      "properties": {
        "score": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100
        },
        "issues": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "product_stack",
              "comparative_overload",
              "scope_adverb",
              "implicit_pivot",
              "authority_without_spec",
              "constraint_conflict",
              "vague_ask",
              "missing_acceptance_criteria"
            ]
          }
        },
        "coaching_shown": {
          "type": "boolean"
        }
      }
    },
    "pivot_log": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["timestamp", "change", "acknowledged_by"],
        "properties": {
          "timestamp": {
            "type": "string",
            "format": "date-time"
          },
          "change": {
            "type": "string",
            "maxLength": 500
          },
          "reason": {
            "type": "string",
            "maxLength": 500
          },
          "acknowledged_by": {
            "type": "string",
            "enum": ["user", "pending"]
          },
          "updates": {
            "type": "object",
            "properties": {
              "in_scope_added": {
                "type": "array",
                "items": { "type": "string" }
              },
              "in_scope_removed": {
                "type": "array",
                "items": { "type": "string" }
              },
              "out_of_scope_added": {
                "type": "array",
                "items": { "type": "string" }
              }
            }
          }
        }
      }
    },
    "correction_log": {
      "type": "array",
      "description": "Distilled corrections: agent mistakes the user corrected, kept as durable rules so they survive context compaction.",
      "items": {
        "type": "object",
        "required": ["id", "timestamp", "wrong", "right", "rule", "acknowledged_by"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^cl-[0-9]+$"
          },
          "timestamp": {
            "type": "string",
            "format": "date-time"
          },
          "wrong": {
            "type": "string",
            "minLength": 3,
            "maxLength": 500,
            "description": "The approach the agent took that was wrong"
          },
          "right": {
            "type": "string",
            "minLength": 3,
            "maxLength": 500,
            "description": "The corrected approach to use instead"
          },
          "rule": {
            "type": "string",
            "minLength": 5,
            "maxLength": 300,
            "description": "Normalized negative constraint capturing the lesson"
          },
          "acknowledged_by": {
            "type": "string",
            "enum": ["user", "pending"]
          },
          "promoted_to_constraint": {
            "type": "boolean"
          }
        }
      }
    },
    "metadata": {
      "type": "object",
      "properties": {
        "project": { "type": "string" },
        "repo_path": { "type": "string" },
        "session_id": { "type": "string" },
        "parent_contract_id": { "type": "string" },
        "superpowers_spec_path": { "type": "string" },
        "external_issue_id": { "type": "string" }
      }
    }
  }
}
