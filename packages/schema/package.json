{
  "name": "@vaultcompass/conductor-schema",
  "version": "1.0.2",
  "type": "module",
  "description": "Intent Contract schema, TypeScript types, and AJV validation",
  "license": "MIT",
  "keywords": ["conductor", "intent-contract", "schema", "ajv", "ai"],
  "repository": {
    "type": "git",
    "url": "https://github.com/vaultcompasshq/conductor.git",
    "directory": "packages/schema"
  },
  "bugs": {
    "url": "https://github.com/vaultcompasshq/conductor/issues"
  },
  "homepage": "https://github.com/vaultcompasshq/conductor#readme",
  "publishConfig": {
    "access": "public",
    "tag": "latest"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "src/intent-contract.schema.json", "README.md"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1"
  },
  "devDependencies": {
    "typescript": "^5.7.3",
    "vitest": "^3.0.5"
  }
}
