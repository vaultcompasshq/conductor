{
  "name": "@vaultcompass/conductor-skill",
  "version": "1.0.8",
  "type": "module",
  "description": "Superpowers-compatible Conductor skills and helper CLIs",
  "license": "MIT",
  "keywords": ["conductor", "superpowers", "skills", "ai", "cursor"],
  "repository": {
    "type": "git",
    "url": "https://github.com/vaultcompasshq/conductor.git",
    "directory": "packages/skill"
  },
  "bugs": {
    "url": "https://github.com/vaultcompasshq/conductor/issues"
  },
  "homepage": "https://github.com/vaultcompasshq/conductor#readme",
  "publishConfig": {
    "access": "public",
    "tag": "latest"
  },
  "bin": {
    "conductor-coach": "./dist/coach-cli.js",
    "conductor-drift": "./dist/drift-cli.js",
    "conductor-extract": "./dist/extract-cli.js",
    "conductor-import-spec": "./dist/import-spec-cli.js",
    "conductor-freeze": "./dist/freeze-cli.js",
    "conductor-init": "./dist/init-cli.js",
    "conductor-index": "./dist/index-cli.js",
    "conductor-check": "./dist/check-cli.js",
    "conductor-correct": "./dist/correct-cli.js",
    "conductor-brief": "./dist/brief-cli.js",
    "conductor-doctor": "./dist/doctor-cli.js",
    "conductor-hook": "./dist/hook-cli.js",
    "conductor-report": "./dist/report-cli.js",
    "conductor-rules": "./dist/rules-cli.js",
    "conductor-pivot": "./dist/pivot-cli.js",
    "conductor-resume": "./dist/resume-cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "intent-contract",
    "prompt-coach",
    "drift-guard",
    "capture-correction"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@vaultcompass/conductor-core": "workspace:*",
    "@vaultcompass/conductor-schema": "workspace:*",
    "yaml": "^2.8.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "typescript": "^5.7.3",
    "vitest": "^3.0.5"
