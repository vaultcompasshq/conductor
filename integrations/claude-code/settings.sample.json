{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PROJECT_DIR}/integrations/hooks/conductor-session-start.sh",
            "args": [],
            "timeout": 30
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PROJECT_DIR}/integrations/hooks/conductor-stop-check.sh",
            "args": [],
            "timeout": 60
          }
        ]
      }
    ]
  }
}
