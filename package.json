{
  "name": "conductor",
  "private": true,
  "version": "1.0.9",
  "description": "Intent fidelity for AI-assisted development",
  "license": "MIT",
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm validate:portfolio-names && pnpm build && pnpm -r test && vitest run examples/validate-examples.test.ts examples/validate-integrations.test.ts examples/validate-offline-lifecycle.test.ts",
    "typecheck": "pnpm -r typecheck",
    "release:smoke": "pnpm build && node scripts/release-smoke.mjs",
    "validate:portfolio-names": "node scripts/validate-no-portfolio-names.mjs",
    "validate:public-repos": "node scripts/validate-public-repos.mjs",
    "publish:beta": "node scripts/publish-beta.mjs",
    "publish:beta:dry-run": "node scripts/publish-beta.mjs --dry-run",
    "publish:bootstrap": "bash scripts/bootstrap-npm-packages.sh",
    "dogfood:app": "bash scripts/dogfood-app.sh",
    "conductor": "node packages/cli/dist/conductor.js",
    "conductor:coach": "node packages/skill/dist/coach-cli.js",
    "conductor:extract": "node packages/skill/dist/extract-cli.js",
    "conductor:import-spec": "node packages/skill/dist/import-spec-cli.js",
    "conductor:freeze": "node packages/skill/dist/freeze-cli.js",
    "conductor:drift": "node packages/skill/dist/drift-cli.js",
    "conductor:init": "node packages/skill/dist/init-cli.js",
    "conductor:index": "node packages/skill/dist/index-cli.js",
    "conductor:check": "node packages/skill/dist/check-cli.js",
    "conductor:correct": "node packages/skill/dist/correct-cli.js",
    "conductor:brief": "node packages/skill/dist/brief-cli.js",
    "conductor:doctor": "node packages/skill/dist/doctor-cli.js",
    "conductor:hook": "node packages/skill/dist/hook-cli.js",
    "conductor:report": "node packages/skill/dist/report-cli.js",
    "conductor:rules": "node packages/skill/dist/rules-cli.js",
    "conductor:pivot": "node packages/skill/dist/pivot-cli.js",
    "conductor:resume": "node packages/skill/dist/resume-cli.js",
    "conductor:install-skills": "bash integrations/superpowers/install-skills.sh",
    "dogfood:cursor-hooks": "pnpm build && node scripts/dogfood-cursor-hooks.mjs"
  },
  "engines": {
    "node": ">=20"
  },
  "pnpm": {
    "overrides": {
      "esbuild": "^0.28.1"
    }
  },
  "devDependencies": {
    "@vaultcompass/conductor-schema": "workspace:*",
    "vitest": "^3.0.5",
    "yaml": "^2.8.0"
  }
}
