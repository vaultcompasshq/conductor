{
  "name": "conductor",
  "private": true,
  "version": "0.3.0-beta.0",
  "description": "Intent fidelity for AI-assisted development",
  "license": "MIT",
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm build && pnpm -r test && vitest run examples/validate-examples.test.ts examples/validate-integrations.test.ts",
    "typecheck": "pnpm -r typecheck",
    "release:smoke": "pnpm build && node scripts/release-smoke.mjs",
    "validate:public-repos": "node scripts/validate-public-repos.mjs",
    "conductor": "node packages/cli/dist/conductor.js",
    "conductor:coach": "node packages/skill/dist/coach-cli.js",
    "conductor:extract": "node packages/skill/dist/extract-cli.js",
    "conductor:freeze": "node packages/skill/dist/freeze-cli.js",
    "conductor:drift": "node packages/skill/dist/drift-cli.js",
    "conductor:init": "node packages/skill/dist/init-cli.js",
    "conductor:index": "node packages/skill/dist/index-cli.js",
    "conductor:check": "node packages/skill/dist/check-cli.js",
    "conductor:correct": "node packages/skill/dist/correct-cli.js",
    "conductor:brief": "node packages/skill/dist/brief-cli.js",
    "conductor:doctor": "node packages/skill/dist/doctor-cli.js",
    "conductor:pivot": "node packages/skill/dist/pivot-cli.js",
    "conductor:resume": "node packages/skill/dist/resume-cli.js",
    "conductor:install-skills": "bash integrations/superpowers/install-skills.sh"
  },
  "engines": {
    "node": ">=20"
  },
  "pnpm": {
    "overrides": {
      "esbuild": "^0.28.1"
    }
  },
  "devDependencies": {
    "@vaultcompasshq/conductor-schema": "workspace:*",
    "vitest": "^3.0.5",
    "yaml": "^2.8.0"
  }
}
